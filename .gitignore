# ===========================================
# Completions - all auto-generated by tools
# ===========================================
# Nearly every CLI tool generates its own completions on install.
# They're always regenerable and version-specific, so ignore the whole directory.
completions/

# ===========================================
# conf.d - auto-generated environment/config
# ===========================================
# Tool-generated environment bootstraps
conf.d/uv.env.fish
conf.d/rustup.fish

# Fish upgrade migration files (created when Fish itself upgrades)
conf.d/fish_frozen_*.fish

# ===========================================
# Fish internal state
# ===========================================
fish_history
fishd.*
.fish_history

# ===========================================
# Local/machine-specific overrides
# ===========================================
conf.d/local.fish
local.fish

# ===========================================
# Backup and swap files
# ===========================================
*.backup-*
*.bak
*.orig
*~
*.swp
